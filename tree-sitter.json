{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "antlr4",
      "camelcase": "Antlr4",
      "title": "Antlr4",
      "scope": "source.antlr4",
      "file-types": [
        "g4"
      ],
      "injection-regex": "^antlr4$",
      "class-name": "TreeSitterAntlr4"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter parser for the Antlr4 parser generator",
    "authors": [
      {
        "name": "Krishin Wadhwani",
        "email": "krishin901@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/lakitu/tree-sitter-antlr4"
    }
  },
  "bindings": {
    "c": false,
    "go": true,
    "java": true,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
